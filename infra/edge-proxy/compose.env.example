# Public DNS + TLS
DOMAIN=ja-geil-gleggmire.duckdns.org
LETSENCRYPT_EMAIL=admin@example.com
BOOTSTRAP_CERT_CN=ja-geil-gleggmire.duckdns.org
LETSENCRYPT_STAGING=0

# Public listener ports for the edge proxy
HTTP_PORT=80
HTTPS_PORT=443

# Renewal/reload intervals
CERTBOT_RENEW_INTERVAL_SECONDS=43200
CERTBOT_BOOTSTRAP_RETRY_SECONDS=300
NGINX_RELOAD_INTERVAL_SECONDS=300
